{
    "$schema": "https://opencode.ai/config.json",
    "provider": {
        "llama.cpp": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "llama-server (local)",
            "options": {
                "baseURL": "https://llm-api.iop.cx/llama.cpp/v1"
            },
            "models": {
                "llama-server (moosntone)": {
                    "name": "Qwen",
                    "limit": {
                        "context": 262144,
                        "output": 65536
                    },
                    "reasoning": true,
                    "options": {
                        "chat_template_kwargs": {
                            "enable_thinking": true
                        }
                    }
                }
            }
        }
    },
    "permission": {
        "*": "ask",
        "read": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": {
            "*": "ask",
            "git *": "allow",
            "grep *": "allow",
        },
        "edit": "ask",
        "lsp": "allow",
        "skill": "allow"
    }
}
